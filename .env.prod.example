# =============================================================================
# FireISP 5.0 — Production Environment Template
# =============================================================================
# Copy this file to .env.prod and fill in ALL required values before starting
# the stack:
#
#   cp .env.prod.example .env.prod
#   nano .env.prod
#   chmod 600 .env.prod
#
# Then bring the stack up:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# ⚠  NEVER commit .env.prod — it is listed in .gitignore.
# =============================================================================

# ---- Application -------------------------------------------------------------
NODE_ENV=production
PORT=3000
APP_URL=https://your-domain.com
LOG_LEVEL=info

# ---- TLS / Let's Encrypt -----------------------------------------------------
# Required by the nginx service and init-letsencrypt.sh.
DOMAIN=your-domain.com
CERTBOT_EMAIL=admin@your-domain.com
# Cloudflare DNS-01 token — only needed for wildcard certificates.
# CF_API_TOKEN=

# ---- MySQL -------------------------------------------------------------------
# DB_HOST must match the docker-compose service name (db-primary).
DB_HOST=db-primary
DB_PORT=3306
DB_USER=fireisp
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_NAME=fireisp
# Root password for the MySQL container (docker-compose.prod.yml only).
DB_ROOT_PASSWORD=CHANGE_ME_strong_root_password

# MySQL replication (docker-compose.prod.yml replica service).
MYSQL_REPL_USER=repl_user
MYSQL_REPL_PASSWORD=CHANGE_ME_strong_repl_password

# ---- Redis -------------------------------------------------------------------
# The :// password must match REDIS_PASSWORD below.
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_MAXMEMORY=256mb

# ---- Read Replica (optional) -------------------------------------------------
# When set, report and dashboard queries are routed to the replica.
# DB_REPLICA_HOST=db-replica
# DB_REPLICA_PORT=3306
# DB_REPLICA_USER=fireisp
# DB_REPLICA_PASSWORD=
# DB_REPLICA_POOL_SIZE=10

# ---- JWT / Sessions ----------------------------------------------------------
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_char_random_hex_string
JWT_EXPIRES_IN=8h
# JWT_ACCESS_EXPIRES_IN=60m
# JWT_REFRESH_EXPIRES_IN=7d

# ---- Encryption (at-rest secrets) --------------------------------------------
# 64-char hex key for AES-256-GCM encryption of payment gateway credentials,
# PAC passwords, CSD keys, and webhook secrets stored in the database.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_64_char_random_hex_string

# ---- CORS -------------------------------------------------------------------
# Comma-separated allowlist of origins (optional — defaults to APP_URL).
# CORS_ORIGINS=https://app.your-domain.com,https://admin.your-domain.com

# ---- Admin IP Allowlist ------------------------------------------------------
# Restrict admin-only endpoints to specific IPs / CIDR ranges (optional).
# ADMIN_IP_ALLOWLIST=10.0.0.0/8,203.0.113.5

# ---- Connection Pool ---------------------------------------------------------
# DB_POOL_SIZE=20
# DB_QUEUE_LIMIT=0

# ---- SMTP / Email ------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@your-domain.com

# ---- Twilio (SMS & WhatsApp) ------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_WHATSAPP_FROM=

# ---- Generic SMS Provider ---------------------------------------------------
# SMS_PROVIDER=generic
# SMS_PROVIDER_URL=https://api.your-mx-gateway.com/v1/messages
# SMS_PROVIDER_API_KEY=
# SMS_PROVIDER_FROM=

# ---- Stripe ------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Conekta -----------------------------------------------------------------
CONEKTA_API_KEY=
CONEKTA_WEBHOOK_KEY=

# ---- PAC Provider (CFDI stamping) --------------------------------------------
# Supported: finkok, sw_sapien
PAC_PROVIDER=finkok
PAC_USER=
PAC_PASSWORD=
PAC_URL=

# ---- RADIUS ------------------------------------------------------------------
RADIUS_SECRET=
RADIUS_HOST=127.0.0.1
RADIUS_COA_PORT=3799
# Embedded RADIUS server — FireISP itself answers Access-Request/Accounting
# (no external FreeRADIUS). See docs/radius-server.md. Defaults ON in prod compose.
RADIUS_SERVER_ENABLED=true
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
# Fallback shared secret for a matched NAS row with no per-NAS secret (optional):
RADIUS_SERVER_SECRET=

# ---- WireGuard (VPN hub) -----------------------------------------------------
# FireISP acts as the hub: NAS routers + technician/support/admin laptops dial in
# and FireISP routes between them to reach customer devices for monitoring and
# troubleshooting. ON BY DEFAULT in production — a normal redeploy activates it; the
# dial-in endpoint auto-derives from DOMAIN (above), and the app auto-generates +
# persists the two server keypairs to the wg_keys volume on first boot. Open UDP
# 51820/51821 in your cloud firewall. See docs/wireguard-setup.md.
# WG_SERVER_ENABLED=false     # uncomment to OPT OUT (the hub is on by default in prod)
# WG_ENDPOINT_HOST=           # optional — defaults to DOMAIN; set to override the public host NAS+clients dial
WG_LISTEN_PORT=51820          # wg-fireisp — NAS routers
WG_CLIENT_LISTEN_PORT=51821   # wg-clients — technician/support/admin laptops
WG_SERVER_SUBNET=10.255.0.0/16
WG_CLIENT_SUBNET=10.99.0.0/16
WG_KEY_DIR=/etc/wireguard     # docker-compose.prod.yml mounts the wg_keys volume here
# WG_SERVER_PUBLIC_KEY / WG_CLIENT_SERVER_PUBLIC_KEY are auto-generated + persisted —
# set them only to pin an externally-managed keypair.

# ---- SNMP Polling ------------------------------------------------------------
SNMP_COMMUNITY=public
SNMP_POLL_INTERVAL=300
# SNMP_POLL_CONCURRENCY=10

# ---- SNMP Trap Receiver ------------------------------------------------------
SNMP_TRAP_PORT=1620

# ---- FireRelay (multi-node clustering) ---------------------------------------
# Mode: standalone (default) | master | worker
FIRERELAY_MODE=standalone
# FIRERELAY_NODES=["https://node2.your-domain.com"]
# FIRERELAY_MASTER_URL=https://node1.your-domain.com
# FIRERELAY_NODE_ID=node2

# ---- Job Queue ---------------------------------------------------------------
# JOB_QUEUE_CONCURRENCY=5

# ---- Request Timeout ---------------------------------------------------------
# REQUEST_TIMEOUT_MS=30000

# ---- Rate Limiting -----------------------------------------------------------
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_API=200
# RATE_LIMIT_AUTH=20
# RATE_LIMIT_TENANT_WINDOW_MS=900000
# RATE_LIMIT_TENANT_API=500

# ---- Feature Flags -----------------------------------------------------------
# FEATURE_CFDI=true
# FEATURE_RADIUS=true
# FEATURE_2FA=true
# FEATURE_WEBHOOKS=true
# FEATURE_SNMP=true

# ---- Error Tracking (Sentry) ------------------------------------------------
# SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0

# ---- Database Backup ---------------------------------------------------------
# BACKUP_S3_BUCKET=
# BACKUP_S3_REGION=us-east-1
# BACKUP_S3_ACCESS_KEY=
# BACKUP_S3_SECRET_KEY=
# BACKUP_S3_ENDPOINT=
# BACKUP_S3_PREFIX=db-backups/
# BACKUP_RETENTION=7

# ---- Data Retention ----------------------------------------------------------
# RETENTION_AUDIT_LOGS_DAYS=365
# RETENTION_ALERT_EVENTS_DAYS=90
# RETENTION_WEBHOOK_DELIVERIES_DAYS=90
# RETENTION_EMAIL_LOGS_DAYS=180
# RETENTION_SMS_LOGS_DAYS=180
# RETENTION_IDEMPOTENCY_KEYS_DAYS=7

# ---- AI Reply Assistant — RAG (Retrieval-Augmented Generation) ---------------
# VECTOR_RETRIEVAL_ENABLED=false
# CHROMA_URL=http://chromadb:8000
