# =============================================================================
# FireISP 5.0 — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your local environment.
# Never commit .env — it is listed in .gitignore.
# =============================================================================

# ---- Application ------------------------------------------------------------
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ---- MySQL ------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fireisp

# ---- JWT / Sessions ---------------------------------------------------------
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=24h

# ---- SMTP (Email Transport) --------------------------------------------------
# Leave SMTP_HOST blank to disable email delivery (messages stay queued).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@fireisp.local

# ---- Scheduler ---------------------------------------------------------------
# Set to 'false' to disable the cron task scheduler on this node.
SCHEDULER_ENABLED=true

# ---- Logging ----------------------------------------------------------------
LOG_LEVEL=debug
