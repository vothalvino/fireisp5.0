# =============================================================================
# FireISP 5.0 — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your local environment.
# Never commit .env — it is listed in .gitignore.
# =============================================================================

# ---- Application ------------------------------------------------------------
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ---- TLS / Let's Encrypt ----------------------------------------------------
# Required when running nginx/init-letsencrypt.sh or the certbot service.
# DOMAIN=isp.example.com
# CERTBOT_EMAIL=admin@example.com
# Cloudflare API Token — required only for DNS-01 / wildcard certificates.
# Create at https://dash.cloudflare.com/profile/api-tokens
# (Zone:Read + DNS:Edit scopes, then `chmod 600 nginx/cloudflare.ini`).
# CF_API_TOKEN=

# ---- MySQL ------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fireisp
# Root password used by docker-compose.prod.yml (separate from app user)
# DB_ROOT_PASSWORD=

# MySQL replication credentials (docker-compose.prod.yml only)
# MYSQL_REPL_USER=repl_user
# MYSQL_REPL_PASSWORD=

# ---- Encryption (at-rest secrets) -------------------------------------------
# 64-char hex key for AES-256-GCM encryption of payment gateway secrets, PAC
# passwords, CSD keys, and webhook secrets stored in the database.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# When unset, values are stored / read as plaintext (development only).
# ENCRYPTION_KEY=

# ---- JWT / Sessions ---------------------------------------------------------
JWT_SECRET=change-me-in-production-this-default-jwt-secret-is-not-secure!!!
JWT_EXPIRES_IN=24h
# JWT_ALGORITHM=HS256  # HS256 (default) or RS256
# Refresh token rotation: short-lived access token + long-lived refresh token.
# JWT_ACCESS_EXPIRES_IN=60m   # Access token lifetime (default: 60 minutes)
# JWT_REFRESH_EXPIRES_IN=7d   # Refresh token lifetime (default: 7 days)

# ---- CORS -------------------------------------------------------------------
# Comma-separated allowlist of origins. If set, overrides the default APP_URL /
# localhost origins. Example: https://app.fireisp.com,https://admin.fireisp.com
# CORS_ORIGINS=

# ---- Admin IP Allowlist ------------------------------------------------------
# Restrict admin endpoints (users, roles, organizations, settings, audit-logs,
# scheduled-tasks, import, billing) to specific IPs or CIDR ranges.
# Comma-separated list of IPv4 addresses and/or CIDR blocks.
# When not set, all IPs are allowed (feature is opt-in).
# Example: ADMIN_IP_ALLOWLIST=10.0.0.0/8,203.0.113.5
# ADMIN_IP_ALLOWLIST=

# ---- Rate Limiting -----------------------------------------------------------
# All values are requests per window. Window default is 15 minutes (900000 ms).
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_API=200
# RATE_LIMIT_AUTH=20
# RATE_LIMIT_PUBLIC=60
# RATE_LIMIT_UPLOAD=30
# RATE_LIMIT_EXPORT=20
# RATE_LIMIT_SSE=10
# RATE_LIMIT_WEBHOOK=100
# Per-tenant limits applied to all authenticated API requests (keyed by org ID)
# RATE_LIMIT_TENANT_WINDOW_MS=900000
# RATE_LIMIT_TENANT_API=500

# ---- Logging ----------------------------------------------------------------
LOG_LEVEL=debug

# ---- SMTP / Email ------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@fireisp.local

# ---- Twilio (SMS & WhatsApp) ------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_WHATSAPP_FROM=

# ---- Generic SMS Provider (local MX gateway / Infobip / MessageBird / etc.) -
# Set SMS_PROVIDER=generic and provide the endpoint URL to use any HTTP-based
# SMS gateway instead of Twilio.  The provider receives a JSON POST body:
#   { "to": "+521234567890", "from": "<SMS_PROVIDER_FROM>", "body": "...", "channel": "sms" }
# and must respond with 2xx.  Set SMS_PROVIDER_API_KEY for Bearer auth.
# SMS_PROVIDER=generic
# SMS_PROVIDER_URL=https://api.your-mx-gateway.com/v1/messages
# SMS_PROVIDER_API_KEY=
# SMS_PROVIDER_FROM=

# ---- Stripe ------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Conekta -----------------------------------------------------------------
CONEKTA_API_KEY=
CONEKTA_WEBHOOK_KEY=

# ---- PAC Provider (CFDI stamping) --------------------------------------------
# Supported: finkok, sw_sapien
PAC_PROVIDER=finkok
PAC_USER=
PAC_PASSWORD=
PAC_URL=

# ---- RADIUS ------------------------------------------------------------------
RADIUS_SECRET=
RADIUS_HOST=127.0.0.1
RADIUS_COA_PORT=3799
# Embedded RADIUS server — FireISP answers RADIUS auth/accounting itself
# (no external FreeRADIUS). See docs/radius-server.md. Off by default in dev.
RADIUS_SERVER_ENABLED=false
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_SERVER_SECRET=

# ---- SNMP Polling ------------------------------------------------------------
SNMP_COMMUNITY=public
SNMP_POLL_INTERVAL=300
# SNMP_POLL_CONCURRENCY=10

# ---- SNMP Trap Receiver ------------------------------------------------------
# UDP port the trap receiver listens on.  Use 162 only when running as root.
# For non-root deployments redirect with iptables:
#   iptables -t nat -A PREROUTING -p udp --dport 162 -j REDIRECT --to-port 1620
SNMP_TRAP_PORT=1620

# ---- MikroTik hAP Lab Integration Tests (Roadmap 3.1) -----------------------
# Set MIKROTIK_HAP_HOST to enable real-hardware integration tests:
#   MIKROTIK_HAP_HOST=<ip>  npx jest tests/mikrotikHapIntegration.test.js
# MIKROTIK_HAP_HOST=
# MIKROTIK_HAP_PORT=8728
# MIKROTIK_HAP_USER=admin
# MIKROTIK_HAP_PASS=

# ---- FireRelay (multi-node clustering) ---------------------------------------
# Mode: standalone (default) | master | worker
FIRERELAY_MODE=standalone
# Master-only: JSON array of worker node URLs
# FIRERELAY_NODES=["https://node2.fireisp.com"]
# FIRERELAY_HEALTH_INTERVAL=30000
# FIRERELAY_REQUEST_TIMEOUT=5000
# FIRERELAY_MAX_RETRIES=3
# Worker-only:
# FIRERELAY_MASTER_URL=https://node1.fireisp.com
# FIRERELAY_NODE_ID=node2
# FIRERELAY_AUTO_INCREMENT_OFFSET=10000001
# Capacity thresholds (all nodes):
# FIRERELAY_MAX_CLIENTS=10000
# FIRERELAY_MAX_DEVICES=3000

# ---- Connection Pool ---------------------------------------------------------
# DB_POOL_SIZE=20
# DB_QUEUE_LIMIT=0
# DB_KEEP_ALIVE_MS=30000

# ---- Read Replica (optional) -------------------------------------------------
# When set, report and dashboard queries are routed to the replica pool.
# Omit (or leave blank) to send all reads to the primary database.
# DB_REPLICA_HOST=
# DB_REPLICA_PORT=3306
# DB_REPLICA_USER=
# DB_REPLICA_PASSWORD=
# DB_REPLICA_POOL_SIZE=10

# ---- Redis / Caching --------------------------------------------------------
# Set REDIS_URL to enable Redis-backed caching and job queues.
# Requires: npm install ioredis (for cache) and/or npm install bullmq (for jobs)
# REDIS_URL=redis://localhost:6379
# Password required in production (docker-compose.prod.yml injects this automatically).
# REDIS_PASSWORD=
# REDIS_MAXMEMORY=256mb

# ---- Job Queue ---------------------------------------------------------------
# JOB_QUEUE_CONCURRENCY=5

# ---- Request Timeout ---------------------------------------------------------
# Maximum request duration in milliseconds (default: 30000 = 30s, 0 = disabled)
# REQUEST_TIMEOUT_MS=30000

# ---- Feature Flags -----------------------------------------------------------
# Enable/disable optional subsystems at runtime (all enabled by default)
# FEATURE_CFDI=true
# FEATURE_RADIUS=true
# FEATURE_2FA=true
# FEATURE_WEBHOOKS=true
# FEATURE_SNMP=true

# ---- Error Tracking (Sentry) -----------------------------------------------
# Set SENTRY_DSN to enable automatic error capturing and reporting to Sentry.
# When not set the integration is disabled and no data is sent (opt-in).
# Obtain your DSN at https://sentry.io/ → Project Settings → Client Keys.
# SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# SENTRY_ENVIRONMENT=production   # defaults to NODE_ENV
# SENTRY_RELEASE=                 # e.g. git tag, CI commit SHA
# SENTRY_TRACES_SAMPLE_RATE=0     # 0–1; set >0 to enable performance tracing

# ---- Data Retention ----------------------------------------------------------
# Override default retention periods (in days). Defaults shown below.
# RETENTION_AUDIT_LOGS_DAYS=365
# RETENTION_ALERT_EVENTS_DAYS=90
# RETENTION_WEBHOOK_DELIVERIES_DAYS=90
# RETENTION_EMAIL_LOGS_DAYS=180
# RETENTION_SMS_LOGS_DAYS=180
# RETENTION_IDEMPOTENCY_KEYS_DAYS=7

# ---- Database Backup ---------------------------------------------------------
# Cloud storage destination for the daily database backup cron job.
# Supports AWS S3 and Backblaze B2 (S3-compatible API).
# When not set, backups are saved locally in storage/backups/ only.
#
# AWS S3 example:
#   BACKUP_S3_BUCKET=my-isp-backups
#   BACKUP_S3_REGION=us-east-1
#   BACKUP_S3_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
#   BACKUP_S3_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
#
# Backblaze B2 example (S3-compatible endpoint):
#   BACKUP_S3_BUCKET=my-isp-backups
#   BACKUP_S3_REGION=us-west-002
#   BACKUP_S3_ACCESS_KEY=<B2 Application Key ID>
#   BACKUP_S3_SECRET_KEY=<B2 Application Key>
#   BACKUP_S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com
#
# BACKUP_S3_BUCKET=
# BACKUP_S3_REGION=us-east-1
# BACKUP_S3_ACCESS_KEY=
# BACKUP_S3_SECRET_KEY=
# BACKUP_S3_ENDPOINT=
# BACKUP_S3_PREFIX=db-backups/
# BACKUP_RETENTION=7

# ---- AI Reply Assistant — RAG (Retrieval-Augmented Generation) ----------------
# Set to 'true' to enable vector retrieval. Requires the chromadb sidecar:
#   docker compose --profile rag up -d
# VECTOR_RETRIEVAL_ENABLED=false
# CHROMA_URL=http://localhost:8000
