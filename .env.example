# =============================================================================
# FireISP 5.0 — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your local environment.
# Never commit .env — it is listed in .gitignore.
# =============================================================================

# ---- Application ------------------------------------------------------------
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ---- MySQL ------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fireisp

# ---- JWT / Sessions ---------------------------------------------------------
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=24h

# ---- Logging ----------------------------------------------------------------
LOG_LEVEL=debug

# ---- SMTP / Email ------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@fireisp.local

# ---- Twilio (SMS & WhatsApp) ------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_WHATSAPP_FROM=

# ---- Stripe ------------------------------------------------------------------
STRIPE_SECRET_KEY=

# ---- Conekta -----------------------------------------------------------------
CONEKTA_API_KEY=

# ---- PAC Provider (CFDI stamping) --------------------------------------------
# Supported: finkok, sw_sapien
PAC_PROVIDER=finkok
PAC_USER=
PAC_PASSWORD=
PAC_URL=

# ---- RADIUS ------------------------------------------------------------------
RADIUS_SECRET=
RADIUS_HOST=127.0.0.1
RADIUS_COA_PORT=3799

# ---- SNMP Polling ------------------------------------------------------------
SNMP_COMMUNITY=public
SNMP_POLL_INTERVAL=300
