{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "FireISP 5.0 — Alerts & Monitoring",
  "uid": "fireisp-alerts",
  "version": 1,
  "tags": ["fireisp", "alerts", "monitoring"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-12h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "panels": [
    {
      "title": "Alert Evaluations / hour",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "increase(http_requests_total{path=~\"/api/v1/alerts.*\"}[1h])",
          "legendFormat": "evaluations/hr",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Webhook Delivery Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total{path=~\"/api/v1/webhooks.*\"}[5m])",
          "legendFormat": "webhooks/s",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Notification Endpoint Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{path=~\"/api/v1/alerts.*|/api/v1/webhooks.*\"}[5m]))",
          "legendFormat": "p95",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "SSE Event Stream Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total{path=~\"/api/v1/events.*\"}[5m])",
          "legendFormat": "SSE req/s",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Audit Log Writes / hour",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "increase(http_requests_total{path=~\"/api/v1/audit-logs.*\",method=\"POST\"}[1h])",
          "legendFormat": "writes/hr",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ]
    },
    {
      "title": "Ticket Activity / hour",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "increase(http_requests_total{path=~\"/api/v1/tickets.*\"}[1h])",
          "legendFormat": "tickets/hr",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ]
    },
    {
      "title": "Scheduled Task Executions / 24h",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "increase(http_requests_total{path=~\"/api/v1/scheduled-tasks.*\"}[24h])",
          "legendFormat": "runs/24h",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ]
    }
  ]
}
