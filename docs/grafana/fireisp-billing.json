{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "FireISP 5.0 — Billing & Revenue",
  "uid": "fireisp-billing",
  "version": 1,
  "tags": ["fireisp", "billing", "revenue"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "panels": [
    {
      "title": "Invoices Generated / hour",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "increase(http_requests_total{path=~\"/api/v1/billing.*\",method=\"POST\"}[1h])",
          "legendFormat": "invoices/hr",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Payment Processing Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total{path=~\"/api/v1/payment-webhooks.*\"}[5m])",
          "legendFormat": "webhooks/s",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Billing Endpoint Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{path=~\"/api/v1/billing.*|/api/v1/invoices.*|/api/v1/payments.*\"}[5m]))",
          "legendFormat": "p95 latency",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Billing Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(http_request_errors_total{path=~\"/api/v1/billing.*|/api/v1/invoices.*|/api/v1/payments.*\"}[5m])",
          "legendFormat": "errors/s",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "red" } }
      }
    },
    {
      "title": "Checkout Sessions / hour",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "increase(http_requests_total{path=~\"/api/v1/checkout.*\",method=\"POST\"}[1h])",
          "legendFormat": "sessions",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ]
    },
    {
      "title": "CFDI Stamp Requests / hour",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "increase(http_requests_total{path=~\"/api/v1/cfdi.*\",method=\"POST\"}[1h])",
          "legendFormat": "stamps",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ]
    },
    {
      "title": "Suspension Actions / hour",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "increase(http_requests_total{path=~\"/api/v1/suspension.*\",method=\"POST\"}[1h])",
          "legendFormat": "actions",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ]
    }
  ]
}
