# Dependencies
node_modules/

# graphify knowledge-graph output (local dev tool, not a repo artifact)
graphify-out/

# npm lockfiles superseded by pnpm-lock.yaml
package-lock.json

# Environment
.env
.env.prod
.env.local

# TLS credentials (never commit secrets)
nginx/cloudflare.ini
nginx/certs/
nginx/letsencrypt/
# Transient backup created by nginx/init-letsencrypt.sh during TLS bootstrap.
# A trap removes it on success; this entry guarantees it never reaches git
# even if the script is interrupted at the wrong moment.
nginx/.nginx.conf.bootstrap-backup

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Coverage
coverage/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Build artifacts
dist/

# Runtime file uploads (ticket / work order attachments)
uploads/
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules
