{
  "name": "fireisp-frontend",
  "version": "5.0.0",
  "description": "FireISP 5.0 — Admin Panel (React + TypeScript + Vite)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "gen:api": "openapi-typescript ../docs/openapi.json -o src/api/schema.d.ts",
    "lint": "tsc --noEmit",
    "test": "echo 'No frontend tests yet — add vitest when writing component tests'"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "openapi-fetch": "^0.12.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "openapi-typescript": "^7.4.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
