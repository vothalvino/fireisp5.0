{
  "name": "fireisp-frontend",
  "version": "5.0.0",
  "description": "FireISP 5.0 — Admin Panel (React + TypeScript + Vite)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run gen:api && tsc --noEmit && vite build",
    "preview": "vite preview",
    "gen:api": "openapi-typescript ../docs/openapi.json -o src/api/schema.d.ts",
    "lint": "pnpm run gen:api && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "i18n:check": "node scripts/i18n-coverage.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@testing-library/dom": "^10.4.1",
    "graphql-request": "^7.4.0",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.6",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.2",
    "openapi-typescript": "^7.4.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^3.2.4"
  }
}
