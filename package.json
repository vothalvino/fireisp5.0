{
  "name": "fireisp",
  "version": "5.0.0",
  "description": "Open source ISP management software — customers, plans, billing, network monitoring, and Mexican fiscal compliance (CFDI 4.0)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/scripts/migrate.js",
    "migrate:smoke-test": "node src/scripts/migrate.js && node src/scripts/migration-smoke-test.js",
    "rollback": "node src/scripts/rollback.js",
    "seed": "node src/scripts/seed.js",
    "loadtest:seed": "node src/scripts/loadtest-seed.js",
    "loadtest": "node src/scripts/loadtest.js",
    "loadtest:soak": "node src/scripts/loadtest-soak.js",
    "backup": "node src/scripts/backup.js",
    "firerelay:agent": "node src/scripts/firerelay-agent.js",
    "admin": "node src/scripts/admin.js",
    "openapi": "node src/scripts/openapi.js",
    "postman": "node src/scripts/postman.js",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:db": "./tests/run_tests.sh",
    "prepare": "husky"
  },
  "keywords": [
    "isp",
    "billing",
    "network",
    "cfdi",
    "radius",
    "snmp"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "glob": "^13.0.6",
    "test-exclude": {
      "glob": "^7.2.0"
    }
  },
  "dependencies": {
    "@node-saml/node-saml": "^5.1.0",
    "@sentry/node": "^10.49.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "graphql": "^16.13.2",
    "graphql-yoga": "^5.21.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.22.0",
    "net-snmp": "^3.26.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "openid-client": "^5.7.1",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "autocannon": "^7.15.0",
    "eslint": "^10.2.0",
    "fast-check": "^4.7.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "optionalDependencies": {
    "bullmq": "^5.76.2",
    "ioredis": "^5.6.1"
  }
}
