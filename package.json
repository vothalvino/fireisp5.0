{
  "name": "fireisp",
  "version": "5.0.0",
  "description": "Open source ISP management software \u2014 customers, plans, billing, network monitoring, and Mexican fiscal compliance (CFDI 4.0)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/scripts/migrate.js",
    "migrate:smoke-test": "node src/scripts/migrate.js && node src/scripts/migration-smoke-test.js",
    "rollback": "node src/scripts/rollback.js",
    "seed": "node src/scripts/seed.js",
    "loadtest:seed": "node src/scripts/loadtest-seed.js",
    "loadtest": "node src/scripts/loadtest.js",
    "loadtest:soak": "node src/scripts/loadtest-soak.js",
    "backup": "node src/scripts/backup.js",
    "verify:volumes": "node src/scripts/verify-volumes.js",
    "firerelay:agent": "node src/scripts/firerelay-agent.js",
    "admin": "node src/scripts/admin.js",
    "openapi": "node src/scripts/openapi.js",
    "spec:check": "node src/scripts/spec-drift.js",
    "sql:check": "node src/scripts/sql-column-check.js",
    "schema:parity": "node src/scripts/schema-parity-check.js",
    "spec:gen": "node src/scripts/gen-route.js",
    "postman": "node src/scripts/postman.js",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:db": "./tests/run_tests.sh",
    "prepare": "if [ -f node_modules/.bin/husky ]; then husky; fi",
    "setup": "bash setup.sh"
  },
  "keywords": [
    "isp",
    "billing",
    "network",
    "cfdi",
    "radius",
    "snmp"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "glob": "^13.0.6",
      "test-exclude>glob": "^7.2.0",
      "ip-address": "^10.1.1",
      "minimatch@10>brace-expansion": "^5.0.6",
      "qs": "^6.15.2",
      "undici": "^7.28.0",
      "@opentelemetry/core": "^2.8.0",
      "form-data": "^4.0.6"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract",
      "unrs-resolver"
    ],
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-gv7w-rqvm-qjhr",
        "GHSA-hmw2-7cc7-3qxx",
        "GHSA-fx2h-pf6j-xcff"
      ]
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@google/generative-ai": "^0.24.1",
    "@node-saml/node-saml": "^5.1.0",
    "@nodecfdi/credentials": "^3.2.0",
    "@sentry/node": "^10.49.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csrf": "^3.1.0",
    "dotenv": "^17.4.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "graphql": "^16.13.2",
    "graphql-yoga": "^5.21.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "mysql2": "^3.22.0",
    "net-snmp": "^3.26.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.1",
    "openai": "^6.35.0",
    "openid-client": "^5.7.1",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "saxon-js": "^2.7.0",
    "web-push": "^3.6.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "autocannon": "^7.15.0",
    "eslint": "^10.2.0",
    "fast-check": "^4.7.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "optionalDependencies": {
    "bullmq": "^5.76.2",
    "ioredis": "^5.6.1"
  }
}
